{
  "info": {
    "_postman_id": "0d1f0ee1-4f89-4f0b-a5f8-3df2a7a37e10",
    "name": "Master Data API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for master data endpoints: supplier master, supplier-item master, and warehouse master. Includes reference notes for supplier and warehouse type values."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login ok', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.access_token) {",
                  "  pm.environment.set('access_token', json.data.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{auth_email}}\",\n  \"password\": \"{{auth_password}}\"\n}"
            },
            "description": "Login with an existing account and save the returned access token into {{access_token}}.",
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Supplier Master",
      "item": [
        {
          "name": "Create Supplier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('supplier created', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('supplier_uuid', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{access_token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplier_name\": \"PT Master Supplier\",\n  \"contact_person\": \"Rina\",\n  \"contact_number\": \"081234567890\",\n  \"email_address\": \"supplier@example.com\",\n  \"material_category\": \"Raw Material\",\n  \"full_address\": \"Jl. Industri No. 1, Bekasi\",\n  \"city\": \"Bekasi\",\n  \"province\": \"Jawa Barat\",\n  \"country\": \"Indonesia\",\n  \"tax_id_npwp\": \"01.234.567.8-901.000\",\n  \"bank_name\": \"BCA\",\n  \"bank_account_number\": \"1234567890\",\n  \"bank_account_name\": \"PT Master Supplier\",\n  \"payment_terms\": \"30 Days\",\n  \"delivery_lead_time_days\": 7,\n  \"status\": \"Active\"\n}"
            },
            "description": "Create supplier master. Valid material_category values: Raw Material, Indirect Raw Material, Subcon.",
            "url": {
              "raw": "{{base_url}}/api/v1/suppliers",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "suppliers"]
            }
          }
        },
        {
          "name": "List Suppliers",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{access_token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "description": "List suppliers. Query params: search, status, material_category, page, limit.",
            "url": {
              "raw": "{{base_url}}/api/v1/suppliers?page=1&limit=10&material_category=Raw Material",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "suppliers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "material_category", "value": "Raw Material" }
              ]
            }
          }
        },
        {
          "name": "Get Supplier Detail",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{access_token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/suppliers/{{supplier_uuid}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "suppliers", "{{supplier_uuid}}"]
            }
          }
        },
