              "raw": "{{base_url}}/api/v1/supplier-items?page=1&limit=10&type=raw_material",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "supplier-items"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "type", "value": "raw_material" }
              ]
            }
          }
        },
