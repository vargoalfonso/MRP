              "raw": "{\n  \"supplier_name\": \"PT Master Supplier Updated\",\n  \"contact_person\": \"Rina Updated\",\n  \"contact_number\": \"081234567891\",\n  \"email_address\": \"supplier-updated@example.com\",\n  \"material_category\": \"Subcon\",\n  \"full_address\": \"Jl. Industri No. 2, Bekasi\",\n  \"city\": \"Bekasi\",\n  \"province\": \"Jawa Barat\",\n  \"country\": \"Indonesia\",\n  \"tax_id_npwp\": \"01.234.567.8-901.000\",\n  \"bank_name\": \"BCA\",\n  \"bank_account_number\": \"1234567891\",\n  \"bank_account_name\": \"PT Master Supplier Updated\",\n  \"payment_terms\": \"45 Days\",\n  \"delivery_lead_time_days\": 10,\n  \"status\": \"Active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/suppliers/{{supplier_uuid}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "suppliers", "{{supplier_uuid}}"]
            }
          }
        },
        {
          "name": "Delete Supplier",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{access_token}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/suppliers/{{supplier_uuid}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "suppliers", "{{supplier_uuid}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Supplier Item Master",
      "item": [
        {
          "name": "Create Supplier Item",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('supplier_item_uniq_code', `SUPITEM-${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('supplier item created', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('supplier_item_uuid', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{access_token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplier_uuid\": \"{{supplier_uuid}}\",\n  \"sebango_code\": \"ASM-LV7-001\",\n  \"uniq_code\": \"{{supplier_item_uniq_code}}\",\n  \"type\": \"raw_material\",\n  \"description\": \"Steel Plate\",\n  \"quantity\": \"40\",\n  \"uom\": \"pcs\",\n  \"weight\": \"2.5\",\n  \"pcs_per_kanban\": \"40\",\n  \"customer_cycle\": \"Daily\",\n  \"status\": \"active\"\n}"
            },
            "description": "Create supplier item. All write payload fields are strings except path params. Valid type values: raw_material, indirect, subcon.",
            "url": {
              "raw": "{{base_url}}/api/v1/supplier-items",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "supplier-items"]
            }
          }
        },
