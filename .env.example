DEV_SHOW_ROUTE=true
APP_ENV="development"
APP_DEBUG=true
APP_VERSION="v1"
APP_NAME="GO-TEMPLATE"
SERVICE_NAME="go-template"

HTTP_SERVER_PORT="8899"
HTTP_READ_TIMEOUT="30s"
HTTP_WRITE_TIMEOUT="30s"
HTTP_IDLE_TIMEOUT="60s"
HTTP_SHUTDOWN_TIMEOUT="10s"
BASE_URL="http://localhost:8899"

# Comma-separated, no wildcard
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080"
RATE_LIMIT_RPS="20"
RATE_LIMIT_BURST="50"
MAX_BODY_BYTES="4194304"

DB_HOST="ep-flat-paper-a1k1y8rh.ap-southeast-1.aws.neon.tech"
DB_PORT="5432"
DB_USERNAME="neondb_owner"
DB_PASSWORD="npg_bpcM8L3yzfna"
DB_NAME="neondb"
DB_SCHEMA="public"
DB_SSL="true"
DB_MAX_CONNECTION="100"
DB_MAX_IDLE_CONNECTION="20"
DB_MAX_LIFETIME_CONNECTION="10m"
DB_MAX_IDLE_TIME="5m"

REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DIAL_TIMEOUT="5s"
REDIS_READ_TIMEOUT="3s"
REDIS_WRITE_TIMEOUT="3s"
REDIS_POOL_SIZE="10"

# "stateful" = access + refresh token (Redis required)
# "stateless" = access token only
JWT_MODE="stateless"

# Generate: openssl rand -base64 64
JWT_ACCESS_SECRET="+GV5yljbUjqKKhBi8EU30WoCnLKrvV9o/SWiyuQVyKRCcpVNPRAr3faCxYj2xIJwHa02GNpLQPjGQDm+53vDmw=="
